---
import { navSections } from '../data/content';
---

<nav class="navdots" aria-label="Section navigation">
  <ul class="navdots__list">
    {
      navSections.map((s) => (
        <li class="navdots__item">
          <a
            href={`#${s.id}`}
            class="navdots__link magnetic"
            data-target={s.id}
            aria-label={s.label}
          >
            <span class="navdots__label">{s.label}</span>
            <span class="navdots__dot" />
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .navdots {
    position: fixed;
    top: 50%;
    right: clamp(1rem, 2.5vw, 2.25rem);
    transform: translateY(-50%);
    z-index: 90;
  }

  .navdots__list {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .navdots__link {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.65rem;
    cursor: pointer;
  }

  .navdots__label {
    font-family: var(--font-heading);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-muted);
    opacity: 0;
    transform: translateX(8px);
    transition: opacity 0.3s ease, transform 0.3s ease, color 0.3s ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .navdots__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid var(--text-dim);
    background: transparent;
    flex-shrink: 0;
    transition: all 0.35s var(--ease-out-expo);
  }

  .navdots__link:hover .navdots__label {
    opacity: 1;
    transform: translateX(0);
    color: var(--accent);
  }

  .navdots__link:hover .navdots__dot {
    border-color: var(--accent);
    transform: scale(1.2);
  }

  .navdots__link.is-active .navdots__dot {
    background: var(--accent);
    border-color: var(--accent);
    /* Highlighted ring border marks the active section. */
    box-shadow: 0 0 0 3px var(--accent-dim), 0 0 10px var(--accent-glow);
    transform: scale(1.3);
  }

  .navdots__link.is-active .navdots__label {
    color: var(--accent);
  }

  @media (max-width: 600px) {
    .navdots {
      right: 0.75rem;
    }
    .navdots__list {
      gap: 0.8rem;
    }
    .navdots__label {
      display: none;
    }
  }
</style>

<script>
  import { lenisInstance } from '@/scripts/smooth-scroll';

  const links = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('.navdots__link')
  );
  const sections = links
    .map((link) => document.getElementById(link.dataset.target || ''))
    .filter((el): el is HTMLElement => el !== null);

  links.forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.getElementById(link.dataset.target || '');
      if (!target) return;
      lenisInstance.scrollTo(target, { offset: 0, duration: 1.4 });
    });
  });

  // Active section = the last one (in document order) whose top has passed a
  // probe line.
  let activeId = '';
  function updateActive() {
    const probe = window.innerHeight * 0.4;
    let currentId = sections[0]?.id ?? '';
    for (const section of sections) {
      if (section.getBoundingClientRect().top <= probe) currentId = section.id;
    }
    if (currentId && currentId !== activeId) {
      activeId = currentId;
      links.forEach((link) =>
        link.classList.toggle('is-active', link.dataset.target === currentId)
      );
    }
  }

  lenisInstance.on('scroll', updateActive);
  window.addEventListener('resize', updateActive);
  updateActive();
</script>
