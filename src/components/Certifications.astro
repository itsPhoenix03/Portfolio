---
import { certifications } from '../data/content';
---

<section class="section section--certifications" id="certifications">
  <span class="ghost-title" data-parallax="0.45" aria-hidden="true">CERTS</span>
  <div class="container certs">
    <header class="certs__head" data-parallax="0.12">
      <span class="certs__eyebrow" data-reveal="up">05 — Certifications</span>
      <h2 class="certs__title" data-reveal="up" data-reveal-delay="0.05">
        Verified <span class="accent">credentials</span>
      </h2>
    </header>

    <div class="certs__grid" data-stagger data-parallax="-0.08">
      {
        certifications.map((cert) => (
          <a
            class="certs__card card stagger-item"
            href={cert.credentialUrl ?? '#'}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="certs__badge" aria-hidden="true">✦</span>
            <h3 class="certs__name">{cert.title}</h3>
            <p class="certs__issuer">{cert.issuer}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .certs {
    width: 100%;
  }

  .certs__head {
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
    text-align: center;
  }

  .certs__eyebrow {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .certs__title {
    color: var(--text-primary);
  }

  .certs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 260px), 1fr));
    gap: 1.25rem;
  }

  .certs__card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
    text-align: left;
  }

  .certs__badge {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    font-size: 1.1rem;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid var(--border-accent);
    transition: box-shadow 0.4s ease, transform 0.4s ease;
  }

  .certs__card:hover .certs__badge {
    animation: glowPulse 1.6s ease-in-out infinite;
    transform: scale(1.05);
  }

  .certs__name {
    font-size: 0.98rem;
    line-height: 1.4;
    color: var(--text-primary);
  }

  .certs__issuer {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }
</style>
