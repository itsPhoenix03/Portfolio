---
import '../styles/global.css';
import { siteMeta, socialLinks } from '../data/content';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Shreyas Misra — Software Engineer',
  description = 'Shreyas Misra is a software engineer building scalable, dependable web applications with React, Next.js, Node.js and TypeScript.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/assets/logo-700.png', Astro.site);
const keywords =
  'Shreyas Misra, software engineer, full stack developer, full-stack software engineer, React developer, Next.js developer, Node.js, TypeScript, web developer, frontend developer, backend developer';

// Person structured data helps search engines understand the site / name.
const socialUrls = socialLinks
  .map((s) => s.href)
  .filter((href) => href.startsWith('http'));
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: siteMeta.name,
  jobTitle: 'Software Engineer',
  description,
  url: Astro.site?.toString(),
  email: siteMeta.email,
  sameAs: socialUrls,
  knowsAbout: [
    'Software Engineering',
    'Full-Stack Development',
    'TypeScript',
    'JavaScript',
    'React',
    'Next.js',
    'Node.js',
    'MongoDB',
    'System Design',
  ],
};
---

<!doctype html>
<html lang="en">
  <script is:inline>
    // Flag JS early so reveal elements can start hidden without FOUC on no-JS.
    document.documentElement.classList.add('js');
    // Set the theme before first paint to avoid a flash.
    (function () {
      try {
        var t = localStorage.getItem('theme');
        if (t !== 'light' && t !== 'dark') {
          t = window.matchMedia('(prefers-color-scheme: light)').matches
            ? 'light'
            : 'dark';
        }
        document.documentElement.dataset.theme = t;
      } catch (e) {
        document.documentElement.dataset.theme = 'dark';
      }
    })();
  </script>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={siteMeta.name} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/assets/logo-700.png" />
    <link rel="apple-touch-icon" href="/assets/logo-700.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#00e5ff" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteMeta.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={`${siteMeta.name} — ${siteMeta.role}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#0a0a0a" />
    <meta name="msapplication-TileColor" content="#0a0a0a" />

    <title>{title}</title>
    <script
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />
  </head>
  <body>
    <div class="preloader" id="preloader">
      <div class="preloader__inner">
        <div class="preloader__logo">
          <span>S</span><span>M</span>
        </div>
        <div class="preloader__bar">
          <span class="preloader__fill" id="preloader-fill"></span>
        </div>
        <div class="preloader__count" id="preloader-count">0</div>
      </div>
    </div>
    <canvas id="hero-canvas" class="bg-canvas" aria-hidden="true"></canvas>
    <div class="site-initials" id="site-initials" aria-hidden="true">
      <span class="site-initials__s">S</span><span class="site-initials__m">M</span>
    </div>
    <div class="site-role" id="site-role" aria-hidden="true">
      <span class="site-role__dot"></span>
      <span class="site-role__text">{siteMeta.role}</span>
    </div>
    <button
      class="theme-toggle magnetic"
      id="theme-toggle"
      aria-label="Toggle light and dark theme"
      data-cursor="Theme"
    >
      <svg
        class="theme-toggle__sun"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path
          d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"
        ></path>
      </svg>
      <svg
        class="theme-toggle__moon"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
      </svg>
    </button>
    <slot />
  </body>
</html>
